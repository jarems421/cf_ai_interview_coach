{
  "name": "cf_ai_interview_coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:api": "wrangler dev --local --port 8787",
    "build": "npm run build:web",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "preview:web": "vite preview --config apps/web/vite.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:local": "wrangler d1 migrations apply interview_coach --local",
    "db:remote": "wrangler d1 migrations apply interview_coach --remote",
    "deploy:api": "wrangler deploy",
    "deploy:web": "npm run build:web && wrangler pages deploy apps/web/dist --project-name cf-ai-interview-coach --branch master"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.561.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "wrangler": "^4.56.0"
  }
}
